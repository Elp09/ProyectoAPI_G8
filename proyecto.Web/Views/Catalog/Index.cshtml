@model List<proyecto.Web.Models.IngestedItem>
@{
    ViewData["Title"] = "Catálogo";
    var sources = ViewBag.Sources as List<proyecto.Web.Models.ApiSource> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0">Catálogo</h4>

    <div class="d-flex align-items-center gap-2">
        <label for="readerLanguage" class="fw-semibold mb-0">Idioma del lector:</label>
        <select id="readerLanguage" class="form-select form-select-sm" style="width: 260px;">
            <option value="es-ES" selected>Español</option>
            <option value="en-US">English</option>
            <option value="pt-BR">Português</option>
            <option value="fr-FR">Français</option>
            <option value="it-IT">Italiano</option>
            <option value="de-DE">Deutsch</option>
            <option value="ru-RU">Русский</option>
            <option value="zh-CN">中文 (China)</option>
            <option value="ja-JP">日本語</option>
            <option value="ko-KR">한국어</option>
            <option value="ar-XA">العربية</option>
            <option value="hi-IN">हिन्दी</option>
        </select>
    </div>
</div>

<!-- Query Panel -->
<div class="card mb-4">
    <div class="card-body">
        @if (!sources.Any())
        {
            <p class="text-muted mb-0">
                No hay APIs configuradas aún.
                <a asp-controller="Apis" asp-action="Index">Agrega una en Mis APIs</a>.
            </p>
        }
        else
        {
            <form asp-action="Ingest" method="post" class="row g-2">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">API</label>
                    <select name="sourceId" id="sourceSelect" class="form-select">
                        @foreach (var source in sources)
                        {
                            <option value="@source.Id"
                                    data-endpoint="@source.Endpoint"
                                    data-url="@source.Url">
                                @source.Name
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="form-label fw-semibold">Ruta del endpoint</label>
                    <div class="input-group">
                        <span class="input-group-text text-muted" id="baseUrlPreview" style="font-size:0.8rem; max-width:160px; overflow:hidden; white-space:nowrap;"></span>
                        <input type="text" class="form-control" name="endpointOverride" id="endpointInput"
                               placeholder="/ruta/del/endpoint" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-dark w-100 d-block">Consultar</button>
                </div>
            </form>
        }
    </div>
</div>

<!-- Upload Panel -->
<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Upload" method="post" enctype="multipart/form-data" class="row g-2">
            <div class="col-md-9">
                <label class="form-label fw-semibold">Subir archivo JSON</label>
                <input type="file" class="form-control" name="file" accept=".json" required />
            </div>
            <div class="col-md-3">
                <label class="form-label">&nbsp;</label>
                <button type="submit" class="btn btn-outline-dark w-100 d-block">Subir</button>
            </div>
        </form>
    </div>
</div>

<!-- Results -->
@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <p>No hay resultados aún. Selecciona una API y haz clic en <strong>Consultar</strong>.</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var item in Enumerable.Reverse(Model))
        {
            var previewText = item.Json.Length > 300 ? item.Json[..300] + "..." : item.Json;

            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <h6 class="card-title mb-0">@(item.IsLocalUpload? item.SourceName: item.SourceName)</h6>
                            @if (item.IsLocalUpload)
                            {
                                <span class="badge bg-secondary">(subido localmente)</span>
                            }
                            else
                            {
                                <span class="badge bg-dark">@item.SourceName</span>
                            }
                        </div>

                        <p class="text-muted small mb-2">
                            <code>@item.Endpoint</code>
                        </p>

                        <p class="card-text text-muted small mb-2">
                            @item.RecordCount registro(s) &middot; @item.FetchedAt.ToString("dd MMM yyyy, HH:mm")
                        </p>

                        <pre id="content-@item.Id"
                             class="bg-light p-2 rounded small mb-0"
                             style="max-height: 120px; overflow: auto;">@previewText</pre>
                    </div>

                    <div class="card-footer bg-transparent">
                        <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center">
                            <div class="d-flex flex-wrap gap-2">
                                <button type="button"
                                        class="btn btn-sm btn-primary"
                                        onclick="playGeneratedAudio('content-@item.Id', '@item.SourceName', this)">
                                    Leer
                                </button>

                                <button type="button"
                                        class="btn btn-sm btn-danger"
                                        onclick="stopGeneratedAudio()">
                                    Detener
                                </button>
                            </div>

                            <a asp-action="Download" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">
                                Descargar JSON
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<audio id="ttsAudioPlayer" style="display:none;"></audio>

@section Scripts {
    <script>
        const sourceSelect = document.getElementById('sourceSelect');
        const endpointInput = document.getElementById('endpointInput');
        const baseUrlPreview = document.getElementById('baseUrlPreview');
        const readerLanguage = document.getElementById('readerLanguage');
        const ttsAudioPlayer = document.getElementById('ttsAudioPlayer');

        let currentAudioUrl = null;
        let currentReadButton = null;

        function updateFields() {
            if (!sourceSelect) return;

            const selected = sourceSelect.options[sourceSelect.selectedIndex];
            const defaultEndpoint = selected.dataset.endpoint || '';
            const baseUrl = selected.dataset.url || '';

            endpointInput.placeholder = defaultEndpoint || '/ruta/del/endpoint';
            endpointInput.value = '';
            baseUrlPreview.textContent = baseUrl;
        }

        if (sourceSelect) {
            sourceSelect.addEventListener('change', updateFields);
            updateFields();
        }

        function resetReadButton() {
            if (currentReadButton) {
                currentReadButton.innerText = 'Leer';
                currentReadButton.disabled = false;
                currentReadButton = null;
            }
        }

        async function playGeneratedAudio(elementId, sourceName, button) {
            const element = document.getElementById(elementId);
            if (!element) return;

            const visibleText = element.innerText.trim();

            if (!visibleText) {
                alert("No hay contenido para leer.");
                return;
            }

            try {
                stopGeneratedAudio();

                currentReadButton = button;
                button.disabled = true;
                button.innerText = "Generando audio...";

                const intro = `Leyendo contenido de ${sourceName}.`;
                const fullText = `${intro} ${visibleText}`;

                const response = await fetch('/Catalog/Speak', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        text: fullText,
                        languageCode: readerLanguage ? readerLanguage.value : 'es-ES'
                    })
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(errorText || 'No se pudo generar el audio.');
                }

                const blob = await response.blob();
                currentAudioUrl = URL.createObjectURL(blob);

                ttsAudioPlayer.src = currentAudioUrl;
                await ttsAudioPlayer.play();

                button.innerText = 'Reproduciendo...';

                ttsAudioPlayer.onended = function () {
                    resetReadButton();

                    if (currentAudioUrl) {
                        URL.revokeObjectURL(currentAudioUrl);
                        currentAudioUrl = null;
                    }
                };
            }
            catch (error) {
                alert("Error al generar el audio: " + error.message);
                resetReadButton();
            }
        }

        function stopGeneratedAudio() {
            if (ttsAudioPlayer) {
                ttsAudioPlayer.pause();
                ttsAudioPlayer.currentTime = 0;
                ttsAudioPlayer.removeAttribute('src');
                ttsAudioPlayer.load();
            }

            if (currentAudioUrl) {
                URL.revokeObjectURL(currentAudioUrl);
                currentAudioUrl = null;
            }

            resetReadButton();
        }
    </script>
}