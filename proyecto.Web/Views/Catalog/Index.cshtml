@model List<proyecto.Web.Models.IngestedItem>
@{
    ViewData["Title"] = "Catálogo";
    var sources = ViewBag.Sources as List<proyecto.Web.Models.ApiSource> ?? new();
    var dbItems = ViewBag.DbItems as List<proyecto.Web.Models.SavedItemDto> ?? new();
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0">Catálogo</h4>
    <div class="d-flex align-items-center gap-2">
        <label for="readerLanguage" class="fw-semibold mb-0">Idioma del lector:</label>
        <select id="readerLanguage" class="form-select form-select-sm" style="width: 200px;">
            <option value="es-ES" selected>Español</option>
            <option value="en-US">English</option>
            <option value="pt-BR">Português</option>
            <option value="fr-FR">Français</option>
            <option value="de-DE">Deutsch</option>
        </select>
    </div>
</div>

<!-- Panel de consulta -->
<div class="card mb-4">
    <div class="card-header fw-semibold">Consultar fuente</div>
    <div class="card-body">
        @if (!sources.Any())
        {
            <p class="text-muted mb-0">No hay APIs configuradas. <a asp-controller="Apis" asp-action="Index">Agrega una</a>.</p>
        }
        else
        {
            <form asp-action="Ingest" method="post" class="row g-2">
                @Html.AntiForgeryToken()
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Fuente</label>
                    <select name="sourceId" id="sourceSelect" class="form-select">
                        @foreach (var s in sources)
                        {
                            <option value="@s.Id" data-endpoint="@s.Endpoint" data-url="@s.Url" data-authtype="@s.AuthType">@s.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="form-label fw-semibold">Endpoint</label>
                    <input type="text" class="form-control form-control-sm bg-light text-muted mb-1" id="baseUrlPreview" readonly tabindex="-1" />
                    <div class="input-group">
                        <input type="text" class="form-control" name="endpointOverride" id="endpointInput" placeholder="/ruta" />
                        <button type="button" class="btn btn-outline-secondary" id="insertSecretBtn" style="display:none;" onclick="insertSecret()" title="Insertar {secret}"><code>{secret}</code></button>
                    </div>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-dark w-100">Consultar</button>
                </div>
            </form>
        }
    </div>
</div>

<!-- Panel de carga -->
<div class="card mb-4">
    <div class="card-header fw-semibold">Subir archivo JSON</div>
    <div class="card-body">
        <form asp-action="Upload" method="post" enctype="multipart/form-data" class="row g-2">
            @Html.AntiForgeryToken()
            <div class="col-md-4">
                <label class="form-label fw-semibold">Nombre de fuente <span class="text-muted fw-normal">(opcional)</span></label>
                <input type="text" class="form-control" name="uploadSourceName" placeholder="Ej: Mis noticias" />
            </div>
            <div class="col-md-5">
                <label class="form-label fw-semibold">Archivo</label>
                <input type="file" class="form-control" name="file" accept=".json" required />
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-outline-dark w-100">Subir</button>
            </div>
        </form>
    </div>
</div>

<!-- Ítems temporales (no guardados) -->
@if (Model.Any())
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Pendientes de guardar <span class="badge bg-warning text-dark">@Model.Count</span></h5>
        <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#clearMemoryModal">Limpiar memoria</button>
    </div>
    <div class="overflow-auto mb-4" style="max-height: 480px;">
    <div class="row g-3">
        @foreach (var item in Enumerable.Reverse(Model))
        {
            var preview = item.Json.Length > 300 ? item.Json[..300] + "..." : item.Json;
            var isHtmlError = item.Json.TrimStart().StartsWith("<");
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 @(isHtmlError ? "border-danger" : "border-warning")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-1">
                            <h6 class="card-title mb-0">@item.SourceName</h6>
                            <div class="d-flex gap-1">
                            @if (isHtmlError)
                            {
                                <span class="badge bg-danger">error al ingestar</span>
                            }
                            @if (item.IsLocalUpload)
                            {
                                <span class="badge bg-secondary">subido</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">temporal</span>
                            }
                            </div>
                        </div>
                        <p class="text-muted small mb-1"><code>@item.Endpoint</code></p>
                        <p class="text-muted small mb-2">@item.FetchedAt.ToString("dd MMM yyyy, HH:mm")</p>
                        <pre id="content-@item.Id" class="bg-light p-2 rounded small mb-0" style="max-height:120px; overflow:auto;">@preview</pre>
                    </div>
                    <div class="card-footer bg-transparent">
                        <div class="d-flex gap-2 flex-wrap">
                            <form asp-action="Save" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-success">Guardar en BD</button>
                            </form>
                            <a asp-action="Download" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">Descargar</a>
                            <button class="btn btn-sm btn-secondary" onclick="showJson('temp-@item.Id', '@item.SourceName')">Ver JSON</button>
                            <button class="btn btn-sm btn-primary" onclick="playGeneratedAudio('content-@item.Id', '@item.SourceName', this)">Leer</button>
                            <button class="btn btn-sm btn-outline-secondary" onclick="stopGeneratedAudio()">Detener</button>
                            <form asp-action="DeleteTemp" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
    </div>
}

<!-- Ítems guardados en BD -->
<h5 class="mb-3">Guardados en BD <span class="badge bg-success">@dbItems.Count</span></h5>
@if (!dbItems.Any())
{
    <div class="text-center text-muted py-4">
        <p>No hay ítems guardados aún. Consulta una fuente y guarda los resultados.</p>
    </div>
}
else
{
    <div class="overflow-auto" style="max-height: 480px;">
    <div class="row g-3">
        @foreach (var item in dbItems)
        {
            var preview = item.Json.Length > 300 ? item.Json[..300] + "..." : item.Json;
            var isHtmlError = item.Json.TrimStart().StartsWith("<");
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 @(isHtmlError ? "border-danger" : "border-success")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-1">
                            <h6 class="card-title mb-0">Ítem #@item.Id</h6>
                            <div class="d-flex gap-1">
                            @if (isHtmlError)
                            {
                                <span class="badge bg-danger">error al ingestar</span>
                            }
                            @if (item.IsLocalUpload)
                            {
                                <span class="badge bg-secondary">subido</span>
                            }
                            else
                            {
                                <span class="badge bg-success">BD</span>
                            }
                            </div>
                        </div>
                        <p class="text-muted small mb-1"><code>@item.Endpoint</code></p>
                        <p class="text-muted small mb-2">
                            @item.CreatedAt.ToString("dd MMM yyyy, HH:mm")
                            @if (!string.IsNullOrEmpty(item.SavedBy))
                            {
                                <span>&middot; @item.SavedBy</span>
                            }
                        </p>
                        <pre id="db-content-@item.Id" class="bg-light p-2 rounded small mb-0" style="max-height:120px; overflow:auto;">@preview</pre>
                    </div>
                    <div class="card-footer bg-transparent">
                        <div class="d-flex gap-2 flex-wrap">
                            <a asp-action="DownloadSaved" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">Descargar</a>
                            <button class="btn btn-sm btn-secondary" onclick="showJson('db-@item.Id', 'Ítem #@item.Id')">Ver JSON</button>
                            <button class="btn btn-sm btn-primary" onclick="playGeneratedAudio('db-content-@item.Id', 'item @item.Id', this)">Leer</button>
                            <button class="btn btn-sm btn-danger" onclick="stopGeneratedAudio()">Detener</button>
                            @if (User.IsInRole("Admin"))
                            {
                                <form asp-action="DeleteSaved" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
    </div>
}

<!-- Clear memory confirmation modal -->
<div class="modal fade" id="clearMemoryModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Limpiar memoria</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                ¿Estás seguro? Se eliminarán todos los ítems pendientes que no han sido guardados en la base de datos.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form asp-action="ClearMemory" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Limpiar</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- JSON viewer modal -->
<div class="modal fade" id="jsonModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="jsonModalLabel">JSON</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <pre id="jsonModalContent" class="m-0 p-3 bg-light" style="font-size:0.8rem; white-space:pre; overflow:auto; max-height:75vh;"></pre>
            </div>
        </div>
    </div>
</div>

<audio id="ttsAudioPlayer" style="display:none;"></audio>

@section Scripts {
<script>
    const sourceSelect = document.getElementById('sourceSelect');
    const endpointInput = document.getElementById('endpointInput');
    const baseUrlPreview = document.getElementById('baseUrlPreview');
    const readerLanguage = document.getElementById('readerLanguage');
    const ttsAudioPlayer = document.getElementById('ttsAudioPlayer');
    let currentAudioUrl = null;
    let currentReadButton = null;

    const insertSecretBtn = document.getElementById('insertSecretBtn');

    function updateFields() {
        if (!sourceSelect) return;
        const selected = sourceSelect.options[sourceSelect.selectedIndex];
        endpointInput.placeholder = selected.dataset.endpoint || '/ruta';
        endpointInput.value = '';
        baseUrlPreview.value = selected.dataset.url || '';
        const isQuery = selected.dataset.authtype === 'query';
        if (insertSecretBtn) insertSecretBtn.style.display = isQuery ? 'block' : 'none';
    }

    function insertSecret() {
        const start = endpointInput.selectionStart;
        const end = endpointInput.selectionEnd;
        const val = endpointInput.value;
        endpointInput.value = val.slice(0, start) + '{secret}' + val.slice(end);
        endpointInput.focus();
        endpointInput.selectionStart = endpointInput.selectionEnd = start + '{secret}'.length;
    }

    if (sourceSelect) { sourceSelect.addEventListener('change', updateFields); updateFields(); }

    function resetReadButton() {
        if (currentReadButton) {
            currentReadButton.innerText = 'Leer';
            currentReadButton.disabled = false;
            currentReadButton = null;
        }
    }

    async function playGeneratedAudio(elementId, sourceName, button) {
        const element = document.getElementById(elementId);
        if (!element) return;

        const visibleText = element.innerText.trim();
        if (!visibleText) { alert("No hay contenido para leer."); return; }

        try {
            stopGeneratedAudio();
            currentReadButton = button;
            button.disabled = true;
            button.innerText = "Generando audio...";

            const fullText = `Leyendo contenido de ${sourceName}. ${visibleText}`;

            const response = await fetch('/Catalog/Speak', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    text: fullText,
                    languageCode: readerLanguage ? readerLanguage.value : 'es-ES'
                })
            });

            if (!response.ok) {
                const errorText = await response.text();
                throw new Error(errorText || 'No se pudo generar el audio.');
            }

            const blob = await response.blob();
            currentAudioUrl = URL.createObjectURL(blob);
            ttsAudioPlayer.src = currentAudioUrl;
            await ttsAudioPlayer.play();
            button.innerText = 'Reproduciendo...';

            ttsAudioPlayer.onended = function () {
                resetReadButton();
                if (currentAudioUrl) { URL.revokeObjectURL(currentAudioUrl); currentAudioUrl = null; }
            };
        } catch (error) {
            alert("Error al generar el audio: " + error.message);
            resetReadButton();
        }
    }

    const _jsonData = {};
    @foreach (var item in Model)
    {
        <text>_jsonData['temp-@item.Id'] = @Html.Raw(Json.Serialize(item.Json));</text>
    }
    @foreach (var item in dbItems)
    {
        <text>_jsonData['db-@item.Id'] = @Html.Raw(Json.Serialize(item.Json));</text>
    }

    function showJson(key, title) {
        const raw = _jsonData[key] ?? '';
        try {
            document.getElementById('jsonModalContent').textContent = JSON.stringify(JSON.parse(raw), null, 2);
        } catch {
            document.getElementById('jsonModalContent').textContent = raw;
        }
        document.getElementById('jsonModalLabel').textContent = title;
        new bootstrap.Modal(document.getElementById('jsonModal')).show();
    }

    function stopGeneratedAudio() {
        if (ttsAudioPlayer) {
            ttsAudioPlayer.pause();
            ttsAudioPlayer.currentTime = 0;
            ttsAudioPlayer.removeAttribute('src');
            ttsAudioPlayer.load();
        }
        if (currentAudioUrl) { URL.revokeObjectURL(currentAudioUrl); currentAudioUrl = null; }
        resetReadButton();
    }
</script>
}
