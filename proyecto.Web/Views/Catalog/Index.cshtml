  {
    "userId": 1,
    "id": 1,
    "title": "sunt aut facere..."
  },
  ...
]</pre>
            </div>
            <div class="card-footer bg-transparent text-end">
                <button class="btn btn-sm btn-outline-dark" onclick="downloadPlaceholder('posts.json')">Descargar JSON</button>
            </div>
        </div>
    </div>

