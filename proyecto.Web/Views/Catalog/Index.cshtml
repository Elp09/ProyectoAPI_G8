@{
    ViewData["Title"] = "Catálogo";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Catálogo</h4>
    <div class="d-flex gap-2">
        <select class="form-select form-select-sm" style="width: auto;">
            <option value="">Todas las APIs</option>
            <option>JSONPlaceholder</option>
            <option>OpenWeather</option>
            <option>GitHub API</option>
        </select>
        <input type="text" class="form-control form-control-sm" placeholder="Buscar objetos..." style="width: 200px;" />
    </div>
</div>

<div class="row g-3">
    <!-- Object Card 1 -->
    <div class="col-md-6 col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <h6 class="card-title mb-0">users.json</h6>
                    <span class="badge bg-dark">JSONPlaceholder</span>
                </div>
                <p class="card-text text-muted small mb-2">10 registros &middot; Ingestado 30 Ene, 2026</p>
                <pre class="bg-light p-2 rounded small mb-0" style="max-height: 120px; overflow: auto;">[
  {
    "id": 1,
    "name": "Leanne Graham",
    "email": "leanne@@example.com"
  },
  ...
]</pre>
            </div>
            <div class="card-footer bg-transparent text-end">
                <button class="btn btn-sm btn-outline-dark" onclick="downloadPlaceholder('users.json')">Descargar JSON</button>
            </div>
        </div>
    </div>

    <!-- Object Card 2 -->
    <div class="col-md-6 col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
