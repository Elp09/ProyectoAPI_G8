@{
    ViewData["Title"] = "Iniciar sesión";
}

<style>
    body { background: #fff; }

    .auth-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 70vh;
        padding: 2rem 1rem;
    }

    .auth-card {
        width: 100%;
        max-width: 380px;
        border: 1px solid #dee2e6;
        border-top: 3px solid #212529;
        border-radius: 6px;
        padding: 2rem;
    }

    .auth-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: #212529;
        margin-bottom: 0.25rem;
    }

    .auth-subtitle {
        font-size: 0.8rem;
        color: #adb5bd;
        margin-bottom: 1.75rem;
    }

    .form-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #adb5bd;
        margin-bottom: 0.3rem;
    }

    .form-control {
        border: 1px solid #dee2e6;
        border-radius: 4px;
        font-size: 0.9rem;
        padding: 0.5rem 0.75rem;
        color: #212529;
    }

    .form-control:focus {
        border-color: #212529;
        box-shadow: none;
    }

    .btn-auth {
        background: #212529;
        border: none;
        color: #fff;
        font-weight: 600;
        font-size: 0.9rem;
        padding: 0.6rem;
        border-radius: 4px;
        width: 100%;
        transition: background 0.15s;
        cursor: pointer;
    }

    .btn-auth:hover { background: #343a40; }

    .auth-footer {
        text-align: center;
        font-size: 0.82rem;
        color: #adb5bd;
        margin-top: 1.25rem;
    }

    .auth-footer a { color: #212529; font-weight: 600; text-decoration: none; }
    .auth-footer a:hover { text-decoration: underline; }
</style>

<div class="auth-wrapper">
    <div class="auth-card">
        <p class="auth-title">Iniciar sesión</p>
        <p class="auth-subtitle">API Ingestor</p>

        <form method="post" asp-action="Login">
            <div class="mb-3">
                <label class="form-label">Correo electrónico</label>
                <input type="email" class="form-control" name="email" placeholder="tu@correo.com" required />
            </div>
            <div class="mb-4">
                <label class="form-label">Contraseña</label>
                <input type="password" class="form-control" name="password" placeholder="••••••••" required />
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="mb-3 text-danger" style="font-size:0.82rem;">
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <button type="submit" class="btn-auth">Entrar</button>
        </form>

        <p class="auth-footer">
            ¿No tenés cuenta? <a asp-controller="Account" asp-action="Register">Registrarse</a>
        </p>
    </div>
</div>
