@{
    ViewData["Title"] = "Login";
}

<div class="d-flex flex-column justify-content-center align-items-center vh-100 bg-light">
    <div class="card p-4 shadow" style="width: 100%; max-width: 400px;">
        <h2 class="mb-3 text-center">Login</h2>
        <form method="post" asp-action="Login">
            <div class="mb-3">
                <label for="loginEmail" class="form-label">Email</label>
                <input type="email" class="form-control form-control-lg" id="loginEmail" name="email" placeholder="tu@correo.com" required />
            </div>
            <div class="mb-3">
                <label for="loginPassword" class="form-label">Password</label>
                <input type="password" class="form-control form-control-lg" id="loginPassword" name="password" placeholder="Contraseña" required />
            </div>
            <div class="mb-3 text-danger">
                <div asp-validation-summary="All"></div>
            </div>
            <button type="submit" class="btn btn-primary w-100 btn-lg">Login</button>
        </form>
        <hr class="my-3" />
        <a href="/Account/Register" class="btn btn-outline-secondary w-100 btn-lg">¿No tienes cuenta? Regístrate</a>
    </div>
</div>