@{
    ViewData["Title"] = "Panel";
}

<h4 class="mb-4">Panel</h4>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card text-bg-dark">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-light-emphasis">APIs configuradas</h6>
                <h2 class="card-title mb-0">3</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-bg-dark">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-light-emphasis">Objetos totales</h6>
                <h2 class="card-title mb-0">47</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-bg-dark">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-light-emphasis">Última ingesta</h6>
                <h2 class="card-title mb-0">Hoy</h2>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>APIs recientes</strong>
                <a asp-controller="Apis" asp-action="Index" class="btn btn-sm btn-outline-dark">Ver todo</a>
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    JSONPlaceholder
                    <span class="badge bg-success">Activo</span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    OpenWeather
                    <span class="badge bg-success">Activo</span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    GitHub API
                    <span class="badge bg-secondary">Inactivo</span>
                </li>
            </ul>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Objetos recientes</strong>
                <a asp-controller="Catalog" asp-action="Index" class="btn btn-sm btn-outline-dark">Ver todo</a>
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    users.json
                    <small class="text-muted">JSONPlaceholder</small>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    weather_ny.json
                    <small class="text-muted">OpenWeather</small>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    repos.json
                    <small class="text-muted">GitHub API</small>
                </li>
            </ul>
        </div>
    </div>
</div>
