@{
    ViewData["Title"] = "Panel";
}

<h4 class="mb-4">Panel</h4>

@if (TempData["Info"] != null)
{
    <div class="alert alert-info">@TempData["Info"]</div>
}

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card text-bg-dark">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-light-emphasis">APIs configuradas</h6>
                <h2 class="card-title mb-0">@ViewBag.SourcesCount</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-bg-dark">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-light-emphasis">Ítems guardados</h6>
                <h2 class="card-title mb-0">@ViewBag.ItemsCount</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-bg-dark">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-light-emphasis">Última ingesta</h6>
                <h2 class="card-title mb-0">
                    @(ViewBag.LastIngest != null
                        ? ((DateTime)ViewBag.LastIngest).ToString("dd MMM")
                        : "—")
                </h2>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>APIs recientes</strong>
                <a asp-controller="Apis" asp-action="Index" class="btn btn-sm btn-outline-dark">Ver todo</a>
            </div>
            <ul class="list-group list-group-flush">
                @if (ViewBag.Sources == null || ((List<proyecto.Web.Models.ApiSource>)ViewBag.Sources).Count == 0)
                {
                    <li class="list-group-item text-muted">No hay APIs configuradas.</li>
                }
                else
                {
                    foreach (var source in (List<proyecto.Web.Models.ApiSource>)ViewBag.Sources)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            @source.Name
                            <span class="badge bg-success">Activo</span>
                        </li>
                    }
                }
            </ul>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Ítems recientes</strong>
                <a asp-controller="Catalog" asp-action="Index" class="btn btn-sm btn-outline-dark">Ver todo</a>
            </div>
            <ul class="list-group list-group-flush">
                @if (ViewBag.RecentItems == null || ((List<proyecto.Web.Models.SavedItemDto>)ViewBag.RecentItems).Count == 0)
                {
                    <li class="list-group-item text-muted">No hay ítems guardados.</li>
                }
                else
                {
                    foreach (var item in (List<proyecto.Web.Models.SavedItemDto>)ViewBag.RecentItems)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>Ítem #@item.Id</span>
                            <small class="text-muted">@item.CreatedAt.ToString("dd MMM HH:mm")</small>
                        </li>
                    }
                }
            </ul>
        </div>
    </div>
</div>
