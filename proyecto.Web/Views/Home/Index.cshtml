@model proyecto.Web.Models.InMemoryStore
@{
    ViewData["Title"] = "Panel";
}

<h4 class="mb-4">Panel</h4>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card text-bg-dark">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-light-emphasis">APIs configuradas</h6>
                <h2 class="card-title mb-0">@Model.Sources.Count</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-bg-dark">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-light-emphasis">Objetos totales</h6>
                <h2 class="card-title mb-0">@Model.Items.Count</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-bg-dark">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-light-emphasis">Última ingesta</h6>
                <h2 class="card-title mb-0">
                    @(Model.Items.Any()
                        ? Model.Items.Max(i => i.FetchedAt).ToString("dd MMM")
                        : "—")
                </h2>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>APIs recientes</strong>
                <a asp-controller="Apis" asp-action="Index" class="btn btn-sm btn-outline-dark">Ver todo</a>
            </div>
            <ul class="list-group list-group-flush">
                @if (!Model.Sources.Any())
                {
                    <li class="list-group-item text-muted">No hay APIs configuradas.</li>
                }
                @foreach (var source in Model.Sources.TakeLast(3).Reverse())
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        @source.Name
                        <span class="badge bg-success">Activo</span>
                    </li>
                }
            </ul>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Objetos recientes</strong>
                <a asp-controller="Catalog" asp-action="Index" class="btn btn-sm btn-outline-dark">Ver todo</a>
            </div>
            <ul class="list-group list-group-flush">
                @if (!Model.Items.Any())
                {
                    <li class="list-group-item text-muted">No hay objetos ingestados.</li>
                }
                @foreach (var item in Model.Items.TakeLast(3).Reverse())
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        @item.SourceName
                        <small class="text-muted">@item.FetchedAt.ToString("dd MMM HH:mm")</small>
                    </li>
                }
            </ul>
        </div>
    </div>
</div>
