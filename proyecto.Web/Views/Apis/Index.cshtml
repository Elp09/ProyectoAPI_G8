@{
    ViewData["Title"] = "Mis APIs";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Mis APIs</h4>
    <button class="btn btn-dark" data-bs-toggle="modal" data-bs-target="#addApiModal">+ Agregar API</button>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>URL base</th>
                <th>Tipo de autenticación</th>
                <th>Estado</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td><strong>JSONPlaceholder</strong></td>
                <td><code>https://jsonplaceholder.typicode.com</code></td>
                <td>Ninguno</td>
                <td><span class="badge bg-success">Activo</span></td>
                <td class="text-end">
                    <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#editApiModal">Editar</button>
                    <button class="btn btn-sm btn-outline-danger">Eliminar</button>
                    <button class="btn btn-sm btn-outline-dark">Ingestar</button>
                </td>
            </tr>
            <tr>
                <td><strong>OpenWeather</strong></td>
                <td><code>https://api.openweathermap.org/data/2.5</code></td>
                <td>Clave API</td>
                <td><span class="badge bg-success">Activo</span></td>
                <td class="text-end">
                    <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#editApiModal">Editar</button>
                    <button class="btn btn-sm btn-outline-danger">Eliminar</button>
                    <button class="btn btn-sm btn-outline-dark">Ingestar</button>
                </td>
            </tr>
            <tr>
                <td><strong>GitHub API</strong></td>
                <td><code>https://api.github.com</code></td>
                <td>Token Bearer</td>
                <td><span class="badge bg-secondary">Inactivo</span></td>
                <td class="text-end">
                    <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#editApiModal">Editar</button>
                    <button class="btn btn-sm btn-outline-danger">Eliminar</button>
                    <button class="btn btn-sm btn-outline-dark">Ingestar</button>
                </td>
            </tr>
        </tbody>
    </table>
</div>

<!-- Add API Modal -->
<div class="modal fade" id="addApiModal" tabindex="-1" aria-labelledby="addApiModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addApiModalLabel">Agregar nueva API</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="mb-3">
                        <label for="apiName" class="form-label">Nombre de la API</label>
                        <input type="text" class="form-control" id="apiName" placeholder="Mi API" />
                    </div>
                    <div class="mb-3">
                        <label for="apiUrl" class="form-label">URL base</label>
                        <input type="url" class="form-control" id="apiUrl" placeholder="https://api.ejemplo.com" />
                    </div>
                    <div class="mb-3">
                        <label for="authType" class="form-label">Tipo de autenticación</label>
                        <select class="form-select" id="authType">
                            <option value="none">Ninguno</option>
                            <option value="apikey">Clave API</option>
                            <option value="bearer">Token Bearer</option>
                            <option value="basic">Autenticación básica</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="apiSecret" class="form-label">Secreto / Clave</label>
                        <input type="password" class="form-control" id="apiSecret" placeholder="Su clave API o token" />
                    </div>
                    <div class="mb-3">
                        <label for="apiEndpoint" class="form-label">Ruta del endpoint</label>
                        <input type="text" class="form-control" id="apiEndpoint" placeholder="/v1/data" />
                        <div class="form-text">El endpoint específico del cual ingestar datos.</div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Guardar API</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit API Modal -->
<div class="modal fade" id="editApiModal" tabindex="-1" aria-labelledby="editApiModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editApiModalLabel">Editar API</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="mb-3">
                        <label for="editApiName" class="form-label">Nombre de la API</label>
                        <input type="text" class="form-control" id="editApiName" value="JSONPlaceholder" />
                    </div>
                    <div class="mb-3">
                        <label for="editApiUrl" class="form-label">URL base</label>
                        <input type="url" class="form-control" id="editApiUrl" value="https://jsonplaceholder.typicode.com" />
                    </div>
                    <div class="mb-3">
                        <label for="editAuthType" class="form-label">Tipo de autenticación</label>
                        <select class="form-select" id="editAuthType">
                            <option value="none" selected>Ninguno</option>
                            <option value="apikey">Clave API</option>
                            <option value="bearer">Token Bearer</option>
                            <option value="basic">Autenticación básica</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="editApiSecret" class="form-label">Secreto / Clave</label>
                        <input type="password" class="form-control" id="editApiSecret" placeholder="Ingrese nueva clave para cambiar" />
                    </div>
                    <div class="mb-3">
                        <label for="editApiEndpoint" class="form-label">Ruta del endpoint</label>
                        <input type="text" class="form-control" id="editApiEndpoint" value="/posts" />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Actualizar API</button>
            </div>
        </div>
    </div>
</div>
