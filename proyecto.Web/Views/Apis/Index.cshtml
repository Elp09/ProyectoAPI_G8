@model List<proyecto.Web.Models.ApiSource>
@{
    ViewData["Title"] = "Mis APIs";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Mis APIs</h4>
    <button class="btn btn-dark" data-bs-toggle="modal" data-bs-target="#addApiModal">+ Agregar API</button>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>URL base</th>
                <th>Tipo de autenticación</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" class="text-center text-muted py-4">No hay APIs configuradas. Agrega una para comenzar.</td>
                </tr>
            }
            @foreach (var source in Model)
            {
                <tr>
                    <td><strong>@source.Name</strong></td>
                    <td><code>@source.Url</code></td>
                    <td>
                        @(source.AuthType switch {
                            "apikey"  => "Clave API",
                            "bearer"  => "Token Bearer",
                            "basic"   => "Autenticación básica",
                            _         => "Ninguno"
                        })
                    </td>
                    <td class="text-end">
                        <form asp-action="Delete" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@source.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Add API Modal -->
<div class="modal fade" id="addApiModal" tabindex="-1" aria-labelledby="addApiModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Add" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="addApiModalLabel">Agregar nueva API</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nombre de la API</label>
                        <input type="text" class="form-control" name="name" placeholder="Mi API" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">URL base</label>
                        <input type="url" class="form-control" name="url" placeholder="https://api.ejemplo.com" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tipo de autenticación</label>
                        <select class="form-select" name="authType">
                            <option value="none">Ninguno</option>
                            <option value="apikey">Clave API</option>
                            <option value="bearer">Token Bearer</option>
                            <option value="basic">Autenticación básica</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Secreto / Clave</label>
                        <input type="password" class="form-control" name="secret" placeholder="Su clave API o token" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ruta del endpoint</label>
                        <input type="text" class="form-control" name="endpoint" placeholder="/v1/data" />
                        <div class="form-text">El endpoint específico del cual ingestar datos.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-dark">Guardar API</button>
                </div>
            </form>
        </div>
    </div>
</div>
