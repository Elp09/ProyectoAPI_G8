@model List<proyecto.Web.Models.ApiSource>
@{
    ViewData["Title"] = "Mis APIs";
    var secretsMap = ViewBag.SecretsMap as Dictionary<int, string> ?? new();
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Mis APIs</h4>
    @if (User.IsInRole("Admin"))
    {
        <button class="btn btn-dark" data-bs-toggle="modal" data-bs-target="#addApiModal">+ Agregar API</button>
    }
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>URL base</th>
                <th>Secreto</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">No hay APIs configuradas. Agrega una para comenzar.</td>
                </tr>
            }
            @foreach (var source in Model)
            {
                <tr>
                    <td><strong>@source.Name</strong><br/><small class="text-muted">@source.Description</small></td>
                    <td><code>@source.Url</code></td>
                    <td>
                        @if (source.RequiresSecret)
                        {
                            <span class="badge @(source.AuthType == "query" ? "bg-info text-dark" : "bg-primary")">
                                @(source.AuthType == "query" ? "Query param" : "Header")
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">No</span>
                        }
                    </td>
                    <td class="text-end">
                        @if (User.IsInRole("Admin"))
                        {
                            <button class="btn btn-sm btn-outline-secondary me-1"
                                    data-secret="@(secretsMap.TryGetValue(source.Id, out var sv) ? sv : "")"
                                    onclick="openEditModal(@source.Id, '@Html.Raw(Html.Encode(source.Name))', '@Html.Raw(Html.Encode(source.Url))', '@Html.Raw(Html.Encode(source.Description ?? ""))', '@Html.Raw(Html.Encode(source.Endpoint ?? ""))', '@source.AuthType', this)">
                                Editar
                            </button>
                            <form asp-action="Delete" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@source.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (User.IsInRole("Admin"))
{
    <!-- Add API Modal -->
    <div class="modal fade" id="addApiModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="Add" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title">Agregar nueva API</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Nombre</label>
                            <input type="text" class="form-control" name="name" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">URL base</label>
                            <input type="url" class="form-control" name="url" placeholder="https://api.ejemplo.com" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Descripción</label>
                            <input type="text" class="form-control" name="description" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Secreto / Clave</label>
                            <input type="password" class="form-control" name="secret" placeholder="Opcional" />
                        </div>
                        <div class="mb-3" id="authTypeGroup" style="display:none;">
                            <label class="form-label">Cómo se envía el secreto</label>
                            <div class="d-flex gap-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="authType" id="authQuery" value="query" checked />
                                    <label class="form-check-label" for="authQuery">Query param <small class="text-muted">(?apikey={secret})</small></label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="authType" id="authHeader" value="header" />
                                    <label class="form-check-label" for="authHeader">Header <small class="text-muted">(Authorization: Bearer)</small></label>
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Endpoint por defecto</label>
                            <input type="text" class="form-control" name="endpoint" placeholder="/v1/data" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-dark">Guardar API</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<!-- Edit API Modal -->
<div class="modal fade" id="editApiModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="editId" />
                <div class="modal-header">
                    <h5 class="modal-title">Editar API</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <input type="text" class="form-control" name="name" id="editName" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">URL base</label>
                        <input type="url" class="form-control" name="url" id="editUrl" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Descripción</label>
                        <input type="text" class="form-control" name="description" id="editDescription" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Secreto / Clave</label>
                        <div class="input-group">
                            <input type="password" class="form-control" name="secret" id="editSecret" placeholder="Opcional" />
                            <button type="button" class="btn btn-outline-secondary" onclick="toggleSecret()" tabindex="-1">
                                <i class="bi bi-eye" id="editSecretEyeIcon"></i>
                            </button>
                        </div>
                    </div>
                    <div class="mb-3" id="editAuthTypeGroup" style="display:none;">
                        <label class="form-label">Cómo se envía el secreto</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="authType" id="editAuthQuery" value="query" />
                                <label class="form-check-label" for="editAuthQuery">Query param <small class="text-muted">(?apikey={secret})</small></label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="authType" id="editAuthHeader" value="header" />
                                <label class="form-check-label" for="editAuthHeader">Header <small class="text-muted">(Authorization: Bearer)</small></label>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Endpoint por defecto</label>
                        <input type="text" class="form-control" name="endpoint" id="editEndpoint" placeholder="/v1/data" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-dark">Guardar cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const secretInput = document.querySelector('input[name="secret"]:not(#editSecret)');
    const authTypeGroup = document.getElementById('authTypeGroup');
    if (secretInput) {
        secretInput.addEventListener('input', () => {
            authTypeGroup.style.display = secretInput.value.trim() ? 'block' : 'none';
        });
    }

    const editSecret = document.getElementById('editSecret');
    const editAuthTypeGroup = document.getElementById('editAuthTypeGroup');
    if (editSecret) {
        editSecret.addEventListener('input', () => {
            editAuthTypeGroup.style.display = editSecret.value.trim() ? 'block' : 'none';
        });
    }

    function toggleSecret() {
        const input = document.getElementById('editSecret');
        const icon = document.getElementById('editSecretEyeIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.className = 'bi bi-eye-slash';
        } else {
            input.type = 'password';
            icon.className = 'bi bi-eye';
        }
    }

    function openEditModal(id, name, url, description, endpoint, authType, btn) {
        document.getElementById('editId').value = id;
        document.getElementById('editName').value = name;
        document.getElementById('editUrl').value = url;
        document.getElementById('editDescription').value = description;
        document.getElementById('editEndpoint').value = endpoint;

        const existingSecret = btn ? btn.dataset.secret : '';
        const secretInput = document.getElementById('editSecret');
        secretInput.value = existingSecret;
        secretInput.type = 'password';
        document.getElementById('editSecretEyeIcon').className = 'bi bi-eye';
        editAuthTypeGroup.style.display = existingSecret ? 'block' : 'none';

        const queryRadio = document.getElementById('editAuthQuery');
        const headerRadio = document.getElementById('editAuthHeader');
        queryRadio.checked = authType !== 'header';
        headerRadio.checked = authType === 'header';

        new bootstrap.Modal(document.getElementById('editApiModal')).show();
    }
</script>
}
